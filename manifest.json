{
  "manifest_version": 3,
  "name": "简易光鸭云",
  "version": "1.0.0",
  "description": "光鸭云盘第三方Chrome浏览器插件 - Material Design风格",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "downloads",
    "notifications",
    "contextMenus",
    "sidePanel"
  ],
  "host_permissions": [
    "https://api.guangyapan.com/*",
    "https://account.guangyapan.com/*",
    "https://*.aliyuncs.com/*"
  ],
  "background": {
    "service_worker": "service-worker.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "popup/popup.html"
  },
  "options_page": "options/options.html"
}
